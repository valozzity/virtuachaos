---
interface Props {
  title: string;
  description: string;
  href: string;
  reverse?: boolean;
}

const { title, description, href, reverse = false } = Astro.props;
---

<article class:list={['card', { 'card--reverse': reverse }]}>
  <a href={href} class="card__image" aria-hidden="true" tabindex="-1">
    <span class="card__image-label">image</span>
  </a>

  <div class="card__content">
    <a href={href} class="surface card__title">
      <span class="t-title">{title}</span>
    </a>

    <div class="surface card__body">
      <p class="t-body">{description}</p>
    </div>

    <div class="card__actions">
      <a href={href} class="btn t-label">read more</a>
      <a
        href="https://instagram.com"
        class="btn btn--icon"
        aria-label="Instagram"
        target="_blank"
        rel="noopener"
      >
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <rect x="2" y="2" width="20" height="20" rx="5" />
          <circle cx="12" cy="12" r="4.5" />
          <circle cx="17.5" cy="6.5" r="1.2" fill="currentColor" stroke="none" />
        </svg>
      </a>
    </div>
  </div>
</article>

<style>
  .card {
    display: grid;
    grid-template-columns: minmax(0, 440px) minmax(0, 1fr);
    gap: clamp(24px, 5vw, 100px);
    align-items: center;
    padding-block: var(--spacing-lg);
  }
  .card--reverse {
    grid-template-columns: minmax(0, 1fr) minmax(0, 440px);
  }
  .card--reverse .card__image {
    order: 2;
  }

  .card__image {
    aspect-ratio: 1 / 1;
    display: flex;
    align-items: center;
    justify-content: center;
    background:
      radial-gradient(circle at 30% 25%, #8a8a8a 0%, #4a4a4a 35%, #1c1c1c 70%, #050505 100%);
    box-shadow:
      0 5px 5.5px rgba(0, 0, 0, 0.1),
      0 20px 10px rgba(0, 0, 0, 0.09),
      0 44px 13px rgba(0, 0, 0, 0.05);
    overflow: hidden;
  }
  .card__image-label {
    color: var(--color-text-muted);
    font-weight: 600;
    font-size: 24px;
    letter-spacing: 0.1em;
    mix-blend-mode: difference;
  }

  .card__content {
    display: flex;
    flex-direction: column;
    gap: 17px;
    min-width: 0;
  }
  .card__title {
    display: flex;
    align-items: center;
    padding: var(--spacing-lg);
    color: var(--color-text-highlight);
  }
  .card__body {
    padding: var(--spacing-sm) var(--spacing-lg);
    color: var(--color-text-primary);
  }
  .card__actions {
    display: flex;
    align-items: center;
    gap: 17px;
  }

  @media (max-width: 720px) {
    .card,
    .card--reverse {
      grid-template-columns: 1fr;
    }
    .card--reverse .card__image {
      order: 0;
    }
  }
</style>
